rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: anyone can read, only owner can write (limited fields)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['displayName', 'photoURL', 'lastLogin']);
    }

    // User data (diary sync): only owner can read/write, with size limit (900KB max)
    match /userData/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.data is string
        && request.resource.data.data.size() <= 900000;
    }

    // Footprints v2: マージ対応（同一訪問者は1ドキュメント）
    match /footprints/{footprintId} {
      allow read: if request.auth != null
        && resource.data.to == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.from == request.auth.uid
        && request.resource.data.keys().hasOnly(['from', 'fromName', 'fromPhoto', 'to', 'createdAt', 'updatedAt', 'visitCount'])
        && request.resource.data.keys().hasAll(['from', 'fromName', 'to', 'createdAt', 'updatedAt', 'visitCount'])
        && request.resource.data.visitCount == 1
        && request.resource.data.from != request.resource.data.to;
      allow update: if request.auth != null
        && resource.data.from == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt', 'visitCount', 'fromName', 'fromPhoto']);
      allow delete: if request.auth != null
        && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }

    // Introductions: ひとこと紹介文（1著者→1対象に1件、100文字以内）
    match /introductions/{introId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['targetUid', 'authorUid', 'authorName', 'authorPhoto', 'text', 'createdAt', 'updatedAt'])
        && request.resource.data.keys().hasAll(['targetUid', 'authorUid', 'text', 'createdAt', 'updatedAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 100
        && request.resource.data.authorUid != request.resource.data.targetUid;
      allow update: if request.auth != null
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'updatedAt', 'authorName', 'authorPhoto'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 100;
      allow delete: if request.auth != null
        && (resource.data.authorUid == request.auth.uid || resource.data.targetUid == request.auth.uid);
    }


    // Friend requests: sender can create, target can read/update (status only, validated values)
    match /friendRequests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.from == request.auth.uid
        && request.resource.data.from != request.resource.data.to
        && request.resource.data.keys().hasOnly(['from', 'fromName', 'to', 'status', 'createdAt'])
        && request.resource.data.keys().hasAll(['from', 'fromName', 'to', 'status', 'createdAt'])
        && request.resource.data.status == 'pending';
      allow read: if request.auth != null
        && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow update: if request.auth != null
        && resource.data.to == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['accepted', 'rejected'];
    }

    // Friends: participants can read/delete, create requires both users validated
    match /friends/{friendId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.users;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users.size() == 2
        && request.resource.data.keys().hasAll(['users', 'createdAt']);
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.users;
    }

    // Footprint read status: restrict writable fields
    match /footprintReadStatus/{userId} {
      allow read: if request.auth != null
        && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['lastReadAt']);
    }

    // Premium status: サーバー(Admin SDK)のみ書き込み、本人のみ読み取り
    match /premium/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Admin SDK only
    }

    // AI usage tracking: サーバー(Admin SDK)のみ書き込み、本人のみ読み取り
    match /aiUsage/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Admin SDK only
    }

    // AI response cache: サーバーのみ読み書き（クライアントアクセス不可）
    match /aiCache/{cacheId} {
      allow read, write: if false; // Admin SDK only
    }

    // Comments: anyone logged in can create, anyone can read, author can delete
    // update は意図的に禁止（コメント編集不可）
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['entryId', 'uid', 'displayName', 'photoURL', 'text', 'createdAt'])
        && request.resource.data.keys().hasAll(['entryId', 'uid', 'text', 'createdAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.entryId is string;
      allow update: if false;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }
  }
}
